# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# Hugging Face (needed for gated models like Llama, and for higher rate limits)
HF_TOKEN=hf_your_token_here

# Optional: default models for `scripts/run_smoke_suite.py` if you omit `--target` / `--draft`
# Quick CPU smoke (no gating):
BENCHMARK_TARGET=distilgpt2
BENCHMARK_DRAFT=distilgpt2

# Proposed “report” pair (requires HF access + GPU in practice — confirm with your teammate):
# BENCHMARK_TARGET=meta-llama/Llama-3.1-8B
# BENCHMARK_DRAFT=meta-llama/Llama-3.2-1B

# Optional: default device for smoke script only (CLI still wins if passed)
# BENCHMARK_DEVICE=cpu
